%% 7-step quick-start workflow: from GitHub download to running Risk Analysis.
%% Used in README § 3.1 (High-level overview).
flowchart TD
    S1["<b>Step 1</b> &middot; Install / update SecurityInsight from GitHub<br/><i>SCRIPTS/Step1_OnboardUpdate_SecurityInsight_from_Github_Repo.ps1</i> &middot; preserves customer files"] --> S2
    S2["<b>Step 2</b> &middot; Onboard SPN + API perms + Azure Reader<br/><i>Step2_OnboardValidate-SecurityInsight-Permissions</i>"] --> S3
    S3["<b>Step 3</b> &middot; Provision Log Analytics workspace + DCE + DCR<br/><i>Step3_OnboardValidate-SecurityInsight-LogAnalytics</i>"] --> S4
    S4["<i>optional</i> &middot; <b>Step 4</b> &middot; Deploy Azure OpenAI (PAYG)<br/><i>Step4_OnboardValidate-SecurityInsight-OpenAI-PAYG-Instance-Azure</i>"] --> S5
    S5["Classify assets with tier tags<br/><i>CriticalAssetTagging</i> &nbsp;&minus;&minus;Scope TEST &rarr; PROD"] --> S6
    S6["Collect identity tiers &rarr; SI_IdentityAssets_CL<br/><i>IdentityAssetsCollectDefineTierIngestLog</i>"] --> S7
    S7["Run Risk Analysis &rarr; xlsx / json / SI_RiskAnalysis_*_CL<br/><i>SecurityInsight_RiskAnalysis</i> &nbsp;&minus;Summary / &minus;Detailed"]

    CFG["<i>optional GUI helper</i><br/>TOOLS/SetupConfigurator/index.html<br/>generates the .custom.ps1 files"] -.-> S3
    CFG -.-> S4

    style S1 fill:#fff4e1,stroke:#b07a00,stroke-width:2px
    style S2 fill:#e8f4fd,stroke:#2a6592
    style S3 fill:#e8f4fd,stroke:#2a6592
    style S4 fill:#e8f4fd,stroke:#2a6592
    style CFG fill:#ede7f6,stroke:#512da8
